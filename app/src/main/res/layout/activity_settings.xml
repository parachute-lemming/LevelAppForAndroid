<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/icon_button_bg"
        android:src="@drawable/ic_back"
        android:contentDescription="@string/settings_back"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        android:layout_marginStart="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bubble_direction"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/readout_bg"
                android:padding="4dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_invert_roll"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/invert_roll"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:paddingHorizontal="12dp"
                    android:minHeight="56dp"
                    app:thumbTint="@color/bubble"
                    app:trackTint="@color/btn_bg_secondary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3038"
                    android:layout_marginHorizontal="12dp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_invert_pitch"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/invert_pitch"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:paddingHorizontal="12dp"
                    android:minHeight="56dp"
                    app:thumbTint="@color/bubble"
                    app:trackTint="@color/btn_bg_secondary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/how_to_check"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/how_to_check_body"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.25"
                android:background="@drawable/readout_bg"
                android:padding="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/alignment_tolerance"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/readout_bg"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alignment_tolerance_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/roll_tolerance_label"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/roll_tol_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="±0.20°"
                        android:textColor="@color/bubble"
                        android:textSize="15sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btn_roll_minus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_button_bg"
                        android:src="@drawable/ic_minus"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/dec_roll" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_roll_tol"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.01"
                        android:valueTo="3.0"
                        android:stepSize="0.01"
                        android:value="0.2"
                        app:thumbColor="@color/bubble"
                        app:trackColorActive="@color/bubble"
                        app:trackColorInactive="@color/btn_bg_secondary"
                        app:haloColor="#33FFB300"
                        app:tickVisible="false" />

                    <ImageButton
                        android:id="@+id/btn_roll_plus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_button_bg"
                        android:src="@drawable/ic_plus"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/inc_roll" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pitch_tolerance_label"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/pitch_tol_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="±0.20°"
                        android:textColor="@color/bubble"
                        android:textSize="15sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btn_pitch_minus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_button_bg"
                        android:src="@drawable/ic_minus"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/dec_pitch" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_pitch_tol"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.01"
                        android:valueTo="3.0"
                        android:stepSize="0.01"
                        android:value="0.2"
                        app:thumbColor="@color/bubble"
                        app:trackColorActive="@color/bubble"
                        app:trackColorInactive="@color/btn_bg_secondary"
                        app:haloColor="#33FFB300"
                        app:tickVisible="false" />

                    <ImageButton
                        android:id="@+id/btn_pitch_plus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_button_bg"
                        android:src="@drawable/ic_plus"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/inc_pitch" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
